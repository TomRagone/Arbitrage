generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// One row per human. Single-user system, but modeled explicitly so access
/// control and audit attribution are first-class. Linked to Supabase auth.users
/// by userId (no cross-schema FK; Supabase owns the auth schema).
model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  email     String   @unique
  isOwner   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("profiles")
}

/// Trading risk configuration. Singleton (id = "singleton").
/// Conservative v1 defaults per spec: 0.5% risk, 1 open position, 3 trades/day.
model Settings {
  id               String   @id @default("singleton")
  accountSize      Decimal  @default(0) @db.Decimal(20, 8)
  riskPctPerTrade  Decimal  @default(0.5) @db.Decimal(6, 4)
  maxOpenPositions Int      @default(1)
  maxTradesPerDay  Int      @default(3)
  takerFeeBps      Int      @default(16)
  baseCurrency     String   @default("USD")
  updatedAt        DateTime @updatedAt

  @@map("settings")
}

/// Global execution safety controls the worker reads BEFORE every action.
/// Singleton (id = "singleton"). trading_enabled defaults FALSE — the system
/// never trades until explicitly armed.
model SystemConfiguration {
  id                              String   @id @default("singleton")
  tradingEnabled                  Boolean  @default(false)
  killSwitchEngaged               Boolean  @default(false)
  killSwitchReason                String?
  circuitBreakerMaxDrawdownPct    Decimal  @default(10) @db.Decimal(6, 3)
  circuitBreakerConsecutiveLosses Int      @default(5)
  maintenanceMode                 Boolean  @default(false)
  /// Taker rate by default (conservative — matches Settings.takerFeeBps).
  feeRateEntryBps                 Int      @default(16)
  /// Taker rate by default (conservative). TP fills could later be modeled
  /// as maker, but the locked default treats every exit as taker.
  feeRateExitBps                  Int      @default(16)
  /// Assumed, not empirically measured — there is no real execution data
  /// yet to calibrate this against. Flagged in cost-report output.
  slippageBps                     Int      @default(5)
  updatedAt                       DateTime @updatedAt

  @@map("system_configuration")
}

/// Append-only audit trail. Made physically immutable by a Postgres trigger
/// (see prisma/sql/audit_immutability.sql) that rejects UPDATE and DELETE.
model AuditLog {
  id        String   @id @default(cuid())
  at        DateTime @default(now())
  actor     String
  action    String
  entity    String?
  entityId  String?
  data      Json?
  ip        String?
  userAgent String?

  @@index([at])
  @@index([action])
  @@map("audit_logs")
}

enum Direction {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
}

/// A paper (dry-run) trade created the moment a signal is approved.
/// initialStop is the permanent 1R risk anchor: made immutable once set by a
/// Postgres trigger (see prisma/sql/trade_immutability.sql) — no code path,
/// app bug, or compromised role can move it after the trade is locked.
model Trade {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  mode            String      @default("PAPER")
  pair            String
  direction       Direction
  status          TradeStatus @default(OPEN)
  entryPrice      Decimal     @db.Decimal(20, 8)
  initialStop     Decimal     @db.Decimal(20, 8)
  takeProfit      Decimal     @db.Decimal(20, 8)
  riskPerUnit     Decimal     @db.Decimal(20, 8)
  rMultipleTarget Decimal     @db.Decimal(6, 3)
  size            Decimal     @db.Decimal(20, 8)
  approvedReason  String?
  exits           TradeExit[]
  stopMoves       TradeStopMove[]

  @@index([status])
  @@index([createdAt])
  @@map("trades")
}

/// Append-only exit/scale-out events for a trade (TP1/TP2/TP3/SL/manual).
/// Made physically immutable the same way as audit_logs — see
/// prisma/sql/trade_immutability.sql.
model TradeExit {
  id          String   @id @default(cuid())
  at          DateTime @default(now())
  tradeId     String
  trade       Trade    @relation(fields: [tradeId], references: [id])
  kind        String
  price       Decimal  @db.Decimal(20, 8)
  sizePortion Decimal  @db.Decimal(20, 8)
  rMultiple   Decimal  @db.Decimal(6, 3)

  @@index([tradeId])
  @@map("trade_exits")
}

/// Append-only stop-move events (e.g. moving to breakeven after TP1).
/// initialStop on Trade never changes — the *current* effective stop for a
/// trade is "latest TradeStopMove for it, else its initialStop." Made
/// physically immutable the same way as trade_exits/audit_logs — see
/// prisma/sql/trade_immutability.sql.
model TradeStopMove {
  id        String   @id @default(cuid())
  at        DateTime @default(now())
  tradeId   String
  trade     Trade    @relation(fields: [tradeId], references: [id])
  fromPrice Decimal  @db.Decimal(20, 8)
  toPrice   Decimal  @db.Decimal(20, 8)
  reason    String

  @@index([tradeId])
  @@map("trade_stop_moves")
}
